# Listo plugin configuration. NORMALLY YOU DON'T EDIT THIS FILE — run /listo:connect in
# Claude Code instead; it writes ~/.listo/.env for you. This template is for advanced/CLI use.
# The ONLY secret is your Listo API key — NEVER put Amazon (AMAZON_SP_*) or Anthropic/Claude
# keys here; those live in the Listo cloud and your own Claude plan respectively.

# Your Listo API key — create it on the Connect page of the Listo web app (/connect).
# Starts with lk_live_. Shown only once at creation.
LISTO_API_KEY=lk_live_xxxxxxxxxxxxxxxxxxxx

# Listo cloud API base URL.
# Local test run of the stack: use http://localhost:8000
LISTO_API_URL=https://api.listo.app

# OPTIONAL — leave this UNSET for normal use. The plugin auto-provisions the engine
# snapshot from the Listo cloud into ~/.listo/engine on first run. Only set this to
# override with your own WRITABLE engine copy (dev): LISTO_ENGINE_DIR=/Users/you/listo-engine
# LISTO_ENGINE_DIR=

# Where the pulled brain bundle is cached locally (optional; default ./.listo).
# LISTO_BRAIN_DIR=.listo
